{% set hero_heading = "Organ Recitals" %}
{% set hero_tagline = "Regular recitals in venues across Surrey." %}
{% set hero_slim = true %}

<div class="lede">{{ organ_recitals.lede | safe }}</div>

<h2 class="section-title">Local venues</h2>
<div class="card-grid">
{% for venue in organ_recitals.venues %}
  <div class="card">
    <h3>{% if venue.url %}<a href="{{ venue.url }}">{{ venue.name }}</a>{% else %}{{ venue.name }}{% endif %}</h3>
    <p class="meta">{{ venue.address }}</p>
  </div>
{% endfor %}
</div>

<div class="contact">
  {{ organ_recitals.footer_note | safe }}
</div>
